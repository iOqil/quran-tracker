datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          Int             @id @default(autoincrement())
  username    String          @unique
  password    String
  role        String          @default("user") // "admin" or "user"
  name        String
  dailyTarget String          @default("1 sura")
  progresses  VerseProgress[]
  todos       Todo[]
  activities  ActivityLog[]
  createdAt   DateTime        @default(now())
}

model Surah {
  id         Int             @id @default(autoincrement())
  number     Int             @unique
  name       String
  verseCount Int
  juz        Int
  isCustom   Boolean         @default(false)
  progresses VerseProgress[]
  createdAt  DateTime        @default(now())
}

model VerseProgress {
  id          Int      @id @default(autoincrement())
  userId      Int
  surahId     Int
  verseNumber Int
  isMemorized Boolean  @default(true)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  surah       Surah    @relation(fields: [surahId], references: [id], onDelete: Cascade)

  @@unique([userId, surahId, verseNumber])
}

model Todo {
  id          Int       @id @default(autoincrement())
  userId      Int
  text        String
  completed   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String   // "todo" or "verse"
  count     Int      @default(1)
  date      String   // YYYY-MM-DD
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, type])
}
